# THE PILOT — variables d'environnement
# Copier vers .env.local pour le dev. Tout passe par Vercel Env + Doppler en prod.
# Aucune valeur réelle ne doit être commitée.

# --- Base de données (Supabase Postgres EU/Frankfurt) ---
DATABASE_URL=postgres://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- IA ---
ANTHROPIC_API_KEY=
ANTHROPIC_MAX_MONTHLY_EUR=500
OPENAI_API_KEY=

# --- OpenRouter (Social Hub uniquement : Grok recherche/redaction + Nano Banana images) ---
# ⚠️ Hors UE (xAI/Google). Barriere anti-PII cote code : aucune donnee investisseur ne transite.
OPENROUTER_API_KEY=
OPENROUTER_GROK_MODEL=x-ai/grok-4.3
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# --- Emails (Brevo) ---
BREVO_API_KEY=
BREVO_WEBHOOK_SECRET=

# --- Envoi email (sécurité) ---
# EMAIL_TEST_MODE=true => tout envoi redirigé vers EMAIL_TEST_ADDRESS (anti-accident)
EMAIL_TEST_MODE=true
EMAIL_TEST_ADDRESS=
EMAIL_SENDER_NAME=SevenAtHome
EMAIL_SENDER_ADDRESS=newsletter@sevenathome.com

# --- Meta Ads (Marketing API) ---
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=1414494822918878
META_BUSINESS_ID=839176021486079
META_WEBHOOK_VERIFY_TOKEN=

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# Optionnel : compte administrateur (MCC) qui gère le compte ci-dessus. Sinon laisser vide.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- LinkedIn Marketing ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Calendly ---
CALENDLY_TOKEN=
CALENDLY_WEBHOOK_SIGNING_KEY=

# --- WhatsApp Business (Pilot Concierge V1.5) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# --- App SAH (source de vérité données investisseurs) ---
SAH_API_BASE_URL=https://app.sevenathome.com
SAH_API_TOKEN=
SAH_WEBHOOK_SECRET=
# Réplique PostgreSQL lecture seule (Option C). Connexion seulement depuis IP whitelistées.
# Format : postgresql://user:password@host:port/dbname?sslmode=require
SAH_DATABASE_URL=

# --- Background jobs (Inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Monitoring ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Cloudflare Access (Zero Trust en frontal) ---
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- DEV UNIQUEMENT : désactive l'authentification en local ---
# DISABLE_AUTH=true  -> plus de page login en dev (accès direct au dashboard).
# Sans effet en production (n'agit que si NODE_ENV != production). À NE JAMAIS déployer.
DISABLE_AUTH=
